# Copy values into your host's dashboard (Render / Vercel / etc.)
# Do NOT commit real secrets. Generate long random strings for JWT/ENCRYPTION.

NODE_ENV=production
APP_NAME=Enterprise IMS

# Public URLs (use your real hostnames after first deploy)
APP_URL=https://YOUR-FRONTEND.onrender.com
API_URL=https://YOUR-API.onrender.com
API_PREFIX=/api/v1
PORT=4000

# Postgres (Render free DB or Neon free tier)
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/enterprise_ims?schema=public

# Redis optional on free tier — app falls back to memory if unavailable
REDIS_URL=redis://localhost:6379

# Secrets — min 32 characters each. Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_ACCESS_SECRET=REPLACE_WITH_LONG_RANDOM_STRING_MIN_32_CHARS
JWT_REFRESH_SECRET=REPLACE_WITH_LONG_RANDOM_STRING_MIN_32_CHARS
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

BCRYPT_ROUNDS=12
ENCRYPTION_KEY=REPLACE_WITH_LONG_RANDOM_STRING_MIN_32

EMAIL_ENABLED=false
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=Enterprise IMS <noreply@your-domain.com>

CORS_ORIGINS=https://YOUR-FRONTEND.onrender.com
DEFAULT_TENANT_SLUG=demo

RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=200

# Frontend build-time only (Vercel / Render static):
# VITE_API_URL=https://YOUR-API.onrender.com/api/v1
