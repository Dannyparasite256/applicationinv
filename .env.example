# Application
NODE_ENV=development
APP_NAME=Enterprise IMS
APP_URL=http://localhost:5173
API_URL=http://localhost:4000
API_PREFIX=/api/v1
PORT=4000

# Database (PostgreSQL)
DATABASE_URL=postgresql://ims:ims_secret@localhost:5432/enterprise_ims?schema=public
DB_HOST=localhost
DB_PORT=5432
DB_USER=ims
DB_PASSWORD=ims_secret
DB_NAME=enterprise_ims

# Redis
REDIS_URL=redis://localhost:6379
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# JWT
JWT_ACCESS_SECRET=change-me-access-secret-min-32-chars-long!!
JWT_REFRESH_SECRET=change-me-refresh-secret-min-32-chars-long!
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Seed / demo users (required for npm run db:seed — never commit real values)
# Copy docs/CREDENTIALS.example.md → docs/CREDENTIALS.local.md for a private notes file
SEED_PASSWORD=change-me-seed-password-min-8
SEED_ADMIN_EMAIL=admin@demo.local
SEED_SUPERADMIN_EMAIL=superadmin@ims.local

# Encryption
BCRYPT_ROUNDS=12
ENCRYPTION_KEY=change-me-32-byte-encryption-key!

# Email (SMTP)
# EMAIL_ENABLED=true with empty SMTP_HOST uses Ethereal (dev preview URLs).
# Real Gmail: smtp.gmail.com:587 + app password.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=Enterprise IMS <noreply@enterprise-ims.local>
EMAIL_ENABLED=true

# SMS (optional)
SMS_PROVIDER=twilio
SMS_API_KEY=
SMS_API_SECRET=
SMS_FROM=
SMS_ENABLED=false

# OAuth Google (optional)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:4000/api/v1/auth/google/callback
OAUTH_GOOGLE_ENABLED=false

# File uploads
MAX_FILE_SIZE_MB=10
UPLOAD_DIR=uploads

# Rate limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100

# Session
SESSION_TIMEOUT_MINUTES=60
MAX_LOGIN_ATTEMPTS=5
LOCKOUT_MINUTES=30

# CORS
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Multi-tenant
DEFAULT_TENANT_SLUG=demo

# Backup
BACKUP_DIR=./backups
BACKUP_RETENTION_DAYS=30

# Live FX rates � https://www.exchangerate-api.com/ (get free key)
EXCHANGE_RATE_API_KEY=

