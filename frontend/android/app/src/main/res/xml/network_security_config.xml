<?xml version="1.0" encoding="utf-8"?>
<!-- Allow cleartext HTTP to local/dev API (phone USB reverse + LAN). Prefer HTTPS in production. -->
<network-security-config>
    <base-config cleartextTrafficPermitted="true">
        <trust-anchors>
            <certificates src="system" />
        </trust-anchors>
    </base-config>
    <domain-config cleartextTrafficPermitted="true">
        <domain includeSubdomains="true">localhost</domain>
        <domain includeSubdomains="true">127.0.0.1</domain>
        <domain includeSubdomains="true">10.0.2.2</domain>
        <domain includeSubdomains="true">10.235.117.17</domain>
        <domain includeSubdomains="true">192.168.100.139</domain>
        <domain includeSubdomains="true">192.168.3.17</domain>
    </domain-config>
</network-security-config>
